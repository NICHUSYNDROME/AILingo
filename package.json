{
  "name": "english-ai-learn",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:browser": "bash -c 'trap \"kill 0\" EXIT; node server/tts-server.cjs & vite'",
    "dev:electron": "NODE_ENV=development electron electron/main.cjs",
    "build": "vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "bash scripts/build.sh --preview",
    "release": "bash scripts/build.sh --release",
    "daemon": "node daemon.cjs",
    "tts-server": "node server/tts-server.cjs",
    "electron:build": "npm run build && electron-builder",
    "pack": "electron-builder --dir",
    "pack:app": "bash scripts/create-app.sh"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12",
    "vitest": "^4.1.7"
  }
}
